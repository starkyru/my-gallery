# App
NODE_ENV=development
PORT=4000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gallery
DATABASE_USER=gallery_user
DATABASE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
ADMIN_INITIAL_PASSWORD=admin
ADMIN_EMAIL=

# SMTP (for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=gallery@ilia.to

# AI
ANTHROPIC_API_KEY=

# Services
SERVICE_ENCRYPTION_KEY=

# Download URL signing (optional, falls back to JWT_SECRET)
DOWNLOAD_SIGNING_KEY=

# Files
UPLOAD_DIR=/var/www/gallery-uploads
PUBLIC_URL=https://overtone.art
CORS_ORIGIN=https://overtone.art

# Frontend
NEXT_PUBLIC_API_URL=https://overtone.art
NEXT_PUBLIC_UPLOAD_URL=https://overtone.art/uploads
API_BACKEND_URL=http://localhost:4000
