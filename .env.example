# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gallery
DATABASE_USER=gallery_user
DATABASE_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
ADMIN_INITIAL_PASSWORD=admin
ADMIN_EMAIL=

# SMTP (for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=gallery@ilia.to

# AI
ANTHROPIC_API_KEY=

# Service Encryption (32-byte hex string for AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_ENCRYPTION_KEY=

# Files
UPLOAD_DIR=/var/www/gallery-uploads
PUBLIC_URL=https://gallery.ilia.to
CORS_ORIGIN=https://gallery.ilia.to

# Frontend
NEXT_PUBLIC_API_URL=https://gallery.ilia.to
NEXT_PUBLIC_UPLOAD_URL=https://gallery.ilia.to/uploads
